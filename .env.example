# ============================================================================
# HomeForge Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your own secure values.
#   cp .env.example .env
#
# NEVER commit the .env file. It is excluded by .gitignore.
# ============================================================================

# --- MariaDB (Nextcloud database) -------------------------------------------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PASSWORD=change_me_db_password
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud

# --- Nextcloud ---------------------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_admin_password

# --- Collabora Online -------------------------------------------------------
COLLABORA_USERNAME=admin
COLLABORA_PASSWORD=change_me_collabora_password

# --- HomeForge Network -------------------------------------------------------
# Your machine's LAN IP — required for Nextcloud Office (Collabora) to work.
# boom.sh and install.sh auto-detect this. Only set manually if auto-detection fails.
# Find it with: hostname -I | awk '{print $1}'  (Linux) or ipconfig getifaddr en0 (Mac)
HOMEFORGE_LAN_IP=

# --- Matrix / Synapse --------------------------------------------------------
# IMPORTANT: MATRIX_DB_PASSWORD must match the password in config/matrix/homeserver.yaml
MATRIX_DB_USER=synapse
MATRIX_DB_PASSWORD=change_me_synapse_password
MATRIX_DB_NAME=synapse
# Generate each with: openssl rand -hex 32
MATRIX_REGISTRATION_SECRET=change_me_generate_with_openssl_rand_hex_32
MATRIX_MACAROON_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
MATRIX_FORM_SECRET=change_me_generate_with_openssl_rand_hex_32

# --- OpenVPN UI --------------------------------------------------------------
# Admin credentials for the OpenVPN web UI (http://<host>:8087)
VPN_ADMIN_USERNAME=admin
VPN_ADMIN_PASSWORD=change_me_vpn_password

# --- Open-WebUI --------------------------------------------------------------
# IMPORTANT: Generate a unique secret key — never reuse or commit it.
# Changing this value logs out all users and invalidates all sessions.
# Generate with: openssl rand -base64 32
WEBUI_SECRET_KEY=change_me_generate_with_openssl_rand_base64_32

# --- Dashboard Test Credentials (used by vitest only, never loaded at runtime) --
# Copy to Dashboard/Dashboard1/.env.test and set secure values.
# These are only read by __tests__/api-auth.test.ts.
TEST_ADMIN_USER=test_admin
TEST_ADMIN_PASSWORD=change_me_test_admin_password
TEST_VIEWER_PASSWORD=change_me_test_viewer_password
