{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": ".",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["scripts/bootstrap.ts"],
  "exclude": ["node_modules", ".next", "app", "components", "lib", "hooks", "public", "custom-server.ts"]
}
